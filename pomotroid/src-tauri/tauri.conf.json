{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PomoDeck",
  "version": "1.5.0",
  "identifier": "com.pomodeck.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "PomoDeck",
        "width": 360,
        "height": 478,
        "minWidth": 240,
        "minHeight": 240,
        "resizable": true,
        "decorations": false,
        "hiddenTitle": true,
        "transparent": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; media-src 'self'"
    }
  },
  "plugins": {
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "copyright": "Copyright © 2025-2026 AJ Studio. MIT License.",
    "shortDescription": "PomoDeck — Flow-state focus timer with hardware integration",
    "longDescription": "PomoDeck is a focus timer with hardware integration for the Logitech MX Creative Console. Features flow scoring, web/app blocking, task management, and a physics-based Pomo Jar.",
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": true
      },
      "rpm": {
        "depends": []
      }
    },
    "macOS": {
      "dmg": {
        "windowPosition": {
          "x": 400,
          "y": 100
        },
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        }
      },
      "minimumSystemVersion": "10.13"
    },
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/128x128.png",
        "installMode": "perMachine"
      },
      "wix": {
        "language": "en-US"
      }
    }
  }
}
